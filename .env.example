# CYBERFRAME Configuration
TERM_USER=admin
TERM_PASS=changeme
SESSION_SECRET=
PORT=3000
VSCODE_PORT=8080

# Agent CLI + Directory
# Use CYBERFRAME_ prefix to avoid conflicts with OpenClaw internal env vars
CYBERFRAME_CLI=openclaw
CYBERFRAME_AGENT_DIR=.openclaw
# WORKSPACE_DIR=C:/Users/YourName/.openclaw/workspace

# OpenClaw Gateway (optional, for AI Chat)
# OPENCLAW_TOKEN=your-gateway-token
# OPENCLAW_GATEWAY=http://127.0.0.1:18789

# For clawdbot users:
# CYBERFRAME_CLI=clawdbot
# CYBERFRAME_AGENT_DIR=.clawdbot

# For moltbot users:
# CYBERFRAME_CLI=moltbot
# CYBERFRAME_AGENT_DIR=.moltbot
